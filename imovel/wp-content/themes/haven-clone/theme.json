{
  "version": 2,
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "base", "color": "#ffffff", "name": "Base" },
        { "slug": "contrast", "color": "#2c2824", "name": "Contrast" },
        { "slug": "primary", "color": "#c8a45e", "name": "Primary Gold" },
        { "slug": "secondary", "color": "#3a6b5e", "name": "Secondary Accent" },
        { "slug": "tertiary", "color": "#faf8f5", "name": "Cream" },
        { "slug": "sand", "color": "#f3efe8", "name": "Sand" },
        { "slug": "dark", "color": "#1a1714", "name": "Dark" }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1280px"
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', Georgia, serif",
          "slug": "display",
          "name": "Display"
        },
        {
          "fontFamily": "'Inter', -apple-system, sans-serif",
          "slug": "body",
          "name": "Body"
        },
        {
          "fontFamily": "'DM Sans', sans-serif",
          "slug": "alt",
          "name": "Alternate"
        }
      ],
      "fluid": true
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "lineHeight": "1.7"
    },
    "elements": {
      "h1": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "clamp(2.5rem, 5vw, 4.5rem)", "fontWeight": "700", "lineHeight": "1.1" }
      },
      "h2": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "clamp(2rem, 3.5vw, 3rem)", "fontWeight": "700", "lineHeight": "1.2" }
      },
      "h3": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "clamp(1.3rem, 2vw, 1.8rem)", "fontWeight": "600" }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "60px" },
        "typography": { "fontFamily": "var(--wp--preset--font-family--alt)", "fontWeight": "600" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
